<?xml version="1.0" encoding="utf-8"?>
<!--
  Reusable inflatable item for a single right-side icon in the TopAppBar.
  FrameLayout wraps the icon + badge so they can overlap correctly.
  Inflated by TopAppBarHelper; badge visibility is toggled programmatically.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/toolbar_icon_touch_size"
    android:layout_height="@dimen/toolbar_icon_touch_size">

    <ImageView
        android:id="@+id/iv_toolbar_icon"
        android:layout_width="@dimen/toolbar_icon_size"
        android:layout_height="@dimen/toolbar_icon_size"
        android:layout_gravity="center"
        android:tint="@color/white" />

    <TextView
        android:id="@+id/tv_toolbar_badge"
        android:layout_width="@dimen/toolbar_badge_size"
        android:layout_height="@dimen/toolbar_badge_size"
        android:layout_gravity="top|end"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="@dimen/toolbar_badge_text_size"
        android:textStyle="bold"
        android:background="@drawable/badge_background"
        android:visibility="gone" />

</FrameLayout>
