<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <include
        android:id="@+id/top_bar"
        layout="@layout/layout_top_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tv_stat_total_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="12dp"
                android:text="0"
                android:textColor="@color/text_primary"
                android:textSize="50sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_stat_total_distance_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="km"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBaseline_toBaselineOf="@+id/tv_stat_total_distance"
                app:layout_constraintStart_toEndOf="@+id/tv_stat_total_distance" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="20dp"
                android:gravity="end"
                android:text="Total distance moved\nwith the club"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@+id/tv_stat_total_distance"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/tv_stat_total_distance_unit"
                app:layout_constraintTop_toTopOf="@+id/tv_stat_total_distance" />

            <TextView
                android:id="@+id/label_activities"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Activities"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/tv_stat_total_distance"
                app:layout_constraintTop_toBottomOf="@id/tv_stat_total_distance" />

            <TextView
                android:id="@+id/tv_stat_total_activities"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:text="0"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@id/label_activities"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/label_activities" />

            <TextView
                android:id="@+id/label_longest_dist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Longest distance"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@id/label_activities"
                app:layout_constraintTop_toBottomOf="@id/label_activities" />

            <TextView
                android:id="@+id/tv_stat_club_record_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 km"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@id/label_longest_dist"
                app:layout_constraintEnd_toEndOf="@id/tv_stat_total_activities"
                app:layout_constraintTop_toTopOf="@id/label_longest_dist" />

            <TextView
                android:id="@+id/label_longest_dur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Longest duration"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@id/label_longest_dist"
                app:layout_constraintTop_toBottomOf="@id/label_longest_dist" />

            <TextView
                android:id="@+id/tv_stat_club_record_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@id/label_longest_dur"
                app:layout_constraintEnd_toEndOf="@id/tv_stat_total_activities"
                app:layout_constraintTop_toTopOf="@id/label_longest_dur" />

            <TextView
                android:id="@+id/label_your_act"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:text="Your activities"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/label_longest_dur" />

            <TextView
                android:id="@+id/label_dist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Distance"
                android:textColor="@color/text_secondary"
                app:layout_constraintStart_toStartOf="@id/label_your_act"
                app:layout_constraintTop_toBottomOf="@id/label_your_act" />

            <TextView
                android:id="@+id/tv_pb_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 km"
                android:textColor="@color/text_primary"
                app:layout_constraintBottom_toBottomOf="@id/label_dist"
                app:layout_constraintEnd_toEndOf="@id/tv_stat_total_activities"
                app:layout_constraintTop_toTopOf="@id/label_dist" />

            <TextView
                android:id="@+id/label_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Time"
                android:textColor="@color/text_secondary"
                app:layout_constraintStart_toStartOf="@id/label_dist"
                app:layout_constraintTop_toBottomOf="@id/label_dist" />

            <TextView
                android:id="@+id/tv_pb_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0h"
                android:textColor="@color/text_primary"
                app:layout_constraintBottom_toBottomOf="@id/label_time"
                app:layout_constraintEnd_toEndOf="@id/tv_stat_total_activities"
                app:layout_constraintTop_toTopOf="@id/label_time" />

            <View
                android:id="@+id/header_bg"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="24dp"
                android:background="#1A1A1A"
                app:layout_constraintTop_toBottomOf="@id/label_time" />

            <TextView
                android:id="@+id/header_rank"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="RANK"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@id/header_bg"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/header_bg" />

            <TextView
                android:id="@+id/header_athlete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="ATHLETE"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@id/header_bg"
                app:layout_constraintStart_toEndOf="@id/header_rank"
                app:layout_constraintTop_toTopOf="@id/header_bg" />

            <TextView
                android:id="@+id/header_distance"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:gravity="end"
                android:text="DISTANCE"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@id/header_bg"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/header_bg" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_leaderboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                app:layout_constraintTop_toBottomOf="@id/header_bg" />

            <ProgressBar
                android:id="@+id/pb_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/header_bg" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>