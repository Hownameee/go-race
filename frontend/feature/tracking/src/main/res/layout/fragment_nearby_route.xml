<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <com.mapbox.maps.MapView
        android:id="@+id/map_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Records button (top-right) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_records"
        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:backgroundTint="@color/surface_dark"
        app:iconTint="@color/text_primary"
        app:icon="@drawable/ic_history"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Compare button (below Records) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_compare"
        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        app:backgroundTint="@color/surface_dark"
        app:iconTint="@color/text_primary"
        app:icon="@drawable/ic_compare"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:layout_constraintTop_toBottomOf="@id/btn_records"
        app:layout_constraintEnd_toEndOf="@id/btn_records" />

    <!-- Loading state: spinner + cancel -->
    <LinearLayout
        android:id="@+id/row_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginBottom="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

    <!-- Bottom area: route info + button rows stacked, anchored to bottom -->
    <LinearLayout
        android:id="@+id/bottom_area"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Route info chip — shown when ROUTE_READY -->
        <LinearLayout
            android:id="@+id/tv_route_info_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/surface_dark"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_route_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- IDLE row: Free Run + Find Nearby -->
        <LinearLayout
            android:id="@+id/row_idle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_free_run"
                android:layout_width="130dp"
                android:layout_height="52dp"
                android:text="Free Run"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                app:backgroundTint="@color/surface_medium"
                app:cornerRadius="26dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_find_nearby"
                android:layout_width="160dp"
                android:layout_height="52dp"
                android:text="Find Nearby"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/error_red"
                app:cornerRadius="26dp" />

        </LinearLayout>

        <!-- ROUTE_READY row: Re-plan + Run Route -->
        <LinearLayout
            android:id="@+id/row_route_ready"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_replan"
                android:layout_width="130dp"
                android:layout_height="52dp"
                android:text="Re-plan"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                app:backgroundTint="@color/surface_medium"
                app:cornerRadius="26dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_run"
                android:layout_width="160dp"
                android:layout_height="52dp"
                android:text="Run Route"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/error_red"
                app:cornerRadius="26dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
