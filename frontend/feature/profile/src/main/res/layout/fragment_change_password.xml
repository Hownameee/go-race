<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical">

    <include
        android:id="@+id/top_bar"
        layout="@layout/layout_top_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Enter your current password to continue."
            android:textColor="@color/text_secondary" />

        <EditText
            android:id="@+id/change_password_current_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="Current password"
            android:inputType="textPassword"
            android:paddingHorizontal="12dp"
            android:paddingVertical="14dp"
            android:textColor="@android:color/black"
            android:textColorHint="@color/text_tertiary" />

        <Button
            android:id="@+id/change_password_submit_button"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_rounded"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="Continue"
            android:textColor="@color/black" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forgot your password?"
                android:textColor="@color/text_tertiary" />

            <Button
                android:id="@+id/change_password_reset_button"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="0dp"
                android:text="Send OTP"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                app:backgroundTint="@null" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
</LinearLayout>
