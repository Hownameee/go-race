<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical">

    <include
        android:id="@+id/top_bar"
        layout="@layout/layout_top_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

        <TextView
            android:id="@+id/change_email_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Your current email has been verified. Enter the new email you want to use."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="New Email"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/change_email_new_email_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="new@email.com"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="12dp"
            android:paddingVertical="14dp"
            android:textColor="@android:color/black"
            android:textColorHint="@color/text_tertiary" />

        <TextView
            android:id="@+id/change_email_new_otp_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="OTP"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:visibility="gone" />

        <EditText
            android:id="@+id/change_email_new_otp_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="6-digit OTP"
            android:inputType="number"
            android:paddingHorizontal="12dp"
            android:paddingVertical="14dp"
            android:textColor="@android:color/black"
            android:textColorHint="@color/text_tertiary"
            android:visibility="gone" />

        <Button
            android:id="@+id/change_email_send_otp_button"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_rounded"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="Send OTP"
            android:textColor="@color/black" />
    </LinearLayout>
</ScrollView>
</LinearLayout>
